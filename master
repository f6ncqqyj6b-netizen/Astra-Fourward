class FourWardNode:
    def __init__(self, node_id: str, secret: str, genesis_anchor: str, difficulty_bits: int = 48, coord_modulus: int = 997):
        self.node_id = node_id
        self.secret = secret
        self.prev_anchor = genesis_anchor
        self.difficulty_bits = difficulty_bits
        self.coord_modulus = coord_modulus
        self.registry = WitnessRegistry()
        self.leaves: List[str] = []
        self.epochs: List[Dict[str, Any]] = []

    def step(self, epoch: int, inputs: Dict[str, Any]) -> Dict[str, Any]:
        prev_anchor_before = self.prev_anchor
        state = compute_state(self.prev_anchor, inputs, epoch, self.node_id)
        state_root = compute_state_root(state)

        beacon_group = collect_witness_group(self.registry.get_sources("beacon"), epoch, self.prev_anchor)
        celestial_group = collect_witness_group(self.registry.get_sources("celestial"), epoch, self.prev_anchor)
        bundle = aggregate_bundle(beacon_group, celestial_group)

        beacon_value = bundle["beacon_digest"]
        celestial_digest = bundle["celestial_digest"]
        seed_hex = derive_seed(self.prev_anchor, beacon_value, celestial_digest)
        prime_value, search_steps, prime_proof = find_prime(seed_hex, min_bits=self.difficulty_bits)

        witness_hash = make_witness_hash(state_root, beacon_value, celestial_digest, prime_value)
        star_leaf = make_star_leaf(epoch, prime_value, seed_hex, witness_hash)
        self.leaves.append(star_leaf)
        merkle_root = merkle_root_hex(self.leaves)
        forward_anchor = compute_forward_anchor(self.prev_anchor, state_root, witness_hash, merkle_root)
        attestation = make_attestation(epoch, self.node_id, self.secret, state_root, forward_anchor, prev_anchor_before)

        x = prime_value % self.coord_modulus
        y = (prime_value // self.coord_modulus) % self.coord_modulus
        z = (prime_value // (self.coord_modulus ** 2)) % self.coord_modulus

        epoch_obj = {
            "epoch": epoch,
            "node_id": self.node_id,
            "prev_anchor": prev_anchor_before,
            "state_root": state_root,
            "beacon_value": beacon_value,
            "celestial_digest": celestial_digest,
            "seed_hex": seed_hex,
            "prime_value": str(prime_value),
            "prime_bits": prime_value.bit_length(),
            "search_steps": search_steps,
            "prime_proof": prime_proof,
            "witness_hash": witness_hash,
            "star_leaf": star_leaf,
            "merkle_root": merkle_root,
            "forward_anchor": forward_anchor,
            "attestation": attestation,
            "witness_bundle": bundle,
            "x": x, "y": y, "z": z
        }
        self.prev_anchor = forward_anchor
        self.epochs.append(epoch_obj)
        return epoch_obj


