def collect_witness_group(sources: list, epoch: int, prev_anchor: str) -> dict:
    normalized = []
    diagnostics = []
    for src in sources:
        raw = src.fetch(epoch, prev_anchor)
        sample = normalize_sample(raw)
        fresh = is_fresh(sample, epoch, src.freshness_window)
        diagnostics.append({"source_id": sample["source_id"], "witness_type": sample["witness_type"], "fresh": fresh, "sample_epoch": sample["sample_epoch"], "freshness_window": src.freshness_window})
        if fresh:
            normalized.append(sample)
    normalized.sort(key=lambda s: s["source_id"])
    digest = domain_hash("FW:WITNESS:GROUP", normalized)
    return {"samples": normalized, "diagnostics": diagnostics, "digest": digest}

def aggregate_bundle(beacon_group: dict, celestial_group: dict) -> dict:
    return {
        "beacon_digest": beacon_group["digest"],
        "celestial_digest": celestial_group["digest"],
        "beacon_quorum_ok": witness_quorum(beacon_group["samples"], 1),
        "celestial_quorum_ok": witness_quorum(celestial_group["samples"], 1),
        "diagnostics": {"beacon": beacon_group["diagnostics"], "celestial": celestial_group["diagnostics"]},
    }


