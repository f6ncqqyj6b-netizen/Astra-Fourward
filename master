outdir = Path("examples/output"); outdir.mkdir(parents=True, exist_ok=True); store = JsonStore(str(outdir / "store"))
genesis_state = {"ledger_name": "ASTRA FourWard", "epoch": 0, "notes": "Master repo canon demo"}
genesis_root = domain_hash("FW:STATE:V1", genesis_state)
genesis_anchor = domain_hash("FW:ANCHOR:V1", {"genesis_root": genesis_root, "label": "GENESIS"})

node_secrets = {"node-a":"alpha-secret","node-b":"beta-secret","node-c":"gamma-secret"}
validator_secrets = {"val-1":"v1-secret","val-2":"v2-secret","val-3":"v3-secret"}
nodes = [FourWardNode("node-a", node_secrets["node-a"], genesis_anchor), FourWardNode("node-b", node_secrets["node-b"], genesis_anchor), FourWardNode("node-c", node_secrets["node-c"], genesis_anchor)]

canon_epochs = []
canon_chain = []
for epoch in range(1, 6):
    proposals = []
    proposal_votes = {}
    records = []
    for node in nodes:
        inputs = {"epoch": epoch, "payload": domain_hash("FW:DEMO-IN:V1", {"epoch": epoch, "node": node.node_id, "prev": node.prev_anchor})[:24]}
        record = node.step(epoch, inputs)
        record["verification_ok"] = verify_epoch(record, node_secrets)
        records.append(record)
        proposal = make_proposal(record)
        proposals.append(proposal)
        proposal_votes[proposal["proposal_id"]] = []

    winning_hint = sorted(proposals, key=lambda p: p["forward_anchor"])[-1]["proposal_id"]
    for validator_id, secret in validator_secrets.items():
        for proposal in proposals:
            decision = "accept" if proposal["proposal_id"] == winning_hint else "reject"
            vote = make_vote(validator_id, secret, proposal["proposal_id"], epoch, decision)
            vote["valid_signature"] = verify_vote(vote, secret)
            proposal_votes[proposal["proposal_id"]].append(vote)

    all_votes = [v for votes in proposal_votes.values() for v in votes]
    faults = detect_equivocation(all_votes)
    canonical = choose_canonical(proposals, proposal_votes, quorum_threshold=2)
    if canonical is not None:
        canon_chain.append(canonical)
    canon_epochs.append({"epoch": epoch, "records": records, "proposals": proposals, "proposal_votes": proposal_votes, "canonical": canonical, "finality": finality_status(canonical["proposal_id"], proposal_votes, 2) if canonical else {"accept_count":0,"quorum_ok":False}, "faults": faults})

