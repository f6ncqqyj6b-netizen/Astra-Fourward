def verify_epoch(epoch: dict, secret_lookup: dict) -> bool:
    if not verify_prime(int(epoch["prime_value"]), epoch["prime_proof"]):
        return False
    if compute_forward_anchor(epoch["prev_anchor"], epoch["state_root"], epoch["witness_hash"], epoch["merkle_root"]) != epoch["forward_anchor"]:
        return False
    att = epoch.get("attestation", {})
    node_id = att.get("node_id")
    if node_id not in secret_lookup:
        return False
    payload = {"epoch": att.get("epoch"), "node_id": att.get("node_id"), "state_root": att.get("state_root"), "forward_anchor": att.get("forward_anchor"), "prev_anchor": att.get("prev_anchor")}
    return verify_attestation(node_id, secret_lookup[node_id], payload, att.get("attestation_signature", ""))


